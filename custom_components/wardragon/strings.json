{
  "config": {
    "step": {
      "user": {
        "title": "WarDragon",
        "description": "Enter the MQTT topic prefix used by your WarDragon kit (default: `wardragon`). Make sure DragonSync's `mqtt_ha_native_mode` flag is set so this integration owns entity creation rather than DragonSync's MQTT auto-discovery.",
        "data": {
          "mqtt_prefix": "MQTT prefix"
        }
      }
    },
    "error": {
      "invalid_prefix": "Prefix must contain only letters, numbers, slashes, dashes, and underscores."
    },
    "abort": {
      "mqtt_required": "The MQTT integration must be set up before installing WarDragon.",
      "already_configured": "This MQTT prefix is already configured."
    }
  },
  "options": {
    "step": {
      "init": {
        "title": "WarDragon options",
        "description": "Tune lifecycle timeouts. Defaults are sensible for most operators.",
        "data": {
          "drone_inactivity_timeout": "Drone inactivity timeout (seconds)",
          "drone_purge_after": "Drone purge after (seconds)",
          "kit_offline_timeout": "Kit offline timeout (seconds)"
        }
      }
    }
  },
  "services": {
    "clear_drone": {
      "name": "Clear drone",
      "description": "Remove a tracked drone from Home Assistant immediately.",
      "fields": {
        "drone_id": {
          "name": "Drone ID",
          "description": "The drone identifier (e.g. drone-F6Q8D244C00CL2KF)."
        }
      }
    },
    "export_drones": {
      "name": "Export drones",
      "description": "Return a JSON snapshot of every currently tracked drone."
    }
  },
  "issues": {
    "mqtt_not_loaded": {
      "title": "MQTT integration not loaded",
      "description": "The WarDragon integration depends on the Home Assistant MQTT integration. Set up MQTT, then reload WarDragon."
    },
    "dragonsync_native_mode_off": {
      "title": "DragonSync `mqtt_ha_native_mode` is off",
      "description": "DragonSync is publishing its own Home Assistant MQTT discovery messages alongside this integration's entities, which produces duplicates. Set `mqtt_ha_native_mode = true` in DragonSync's `config.ini` and restart DragonSync."
    }
  },
